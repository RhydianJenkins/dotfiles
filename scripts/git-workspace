#!/usr/bin/env bash

usage() {
    echo "usage: git workspace <command>"
    echo ""
    echo "A 'workspace' is a directory containing multiple git repositories."
    echo "It is a term borrowed from go workspaces."
    echo ""
    echo "commands:"
    echo "  pull    pull all repos in the workspace"
    echo "  status  list repos in the workspace with uncommitted changes"
    echo "  main    checkout main/master on all repos in the workspace, skipping dirty ones
  reset   discard all uncommitted changes in dirty repos (prompts for confirmation)"
    exit 1
}

git_repos() {
    for dir in */; do
        [ -d "$dir/.git" ] && echo "${dir%/}"
    done
}

pull() {
    git_repos | xargs -P 10 -I{} sh -c 'echo Pulling {}; git -C "{}" pull'
}

status() {
    git_repos |
    while read -r dir; do
        local_status=$(git -C "$dir" status --porcelain 2>/dev/null)
        branch=$(git -C "$dir" rev-parse --abbrev-ref HEAD 2>/dev/null)
        unpushed=$(git -C "$dir" cherry -v "@{upstream}" 2>/dev/null | wc -l | tr -d ' ')

        parts=()
        if [ -n "$local_status" ]; then
            count=$(echo "$local_status" | wc -l | tr -d ' ')
            parts+=("$count file(s) changed")
        fi
        if [ "$unpushed" -gt 0 ] 2>/dev/null; then
            parts+=("$unpushed unpushed commit(s)")
        fi

        if [ "${#parts[@]}" -gt 0 ]; then
            msg=$(IFS=', '; echo "${parts[*]}")
            echo "$dir ($branch): $msg"
        fi
    done
}

main() {
    git_repos |
    while read -r dir; do
        if [ -n "$(git -C "$dir" status --porcelain 2>/dev/null)" ]; then
            echo "Skipping $dir: uncommitted changes"
            continue
        fi
        default=$(git -C "$dir" symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's|refs/remotes/origin/||')
        if [ -z "$default" ]; then
            if git -C "$dir" rev-parse --verify main &>/dev/null; then
                default="main"
            elif git -C "$dir" rev-parse --verify master &>/dev/null; then
                default="master"
            else
                echo "Skipping $dir: could not determine default branch"
                continue
            fi
        fi
        git -C "$dir" checkout "$default"
    done
}

reset() {
    dirty=()
    while read -r dir; do
        if [ -n "$(git -C "$dir" status --porcelain 2>/dev/null)" ]; then
            dirty+=("$dir")
        fi
    done < <(git_repos)

    if [ "${#dirty[@]}" -eq 0 ]; then
        echo "Nothing to reset."
        return
    fi

    echo "The following repos have uncommitted changes and will be reset:"
    for dir in "${dirty[@]}"; do
        echo "  $dir"
    done
    echo ""
    printf "Are you sure? [y/n] "
    read -r answer
    if [[ "$answer" != "y" && "$answer" != "Y" ]]; then
        echo "Aborted."
        return
    fi

    for dir in "${dirty[@]}"; do
        echo "Resetting $dir..."
        git -C "$dir" reset --hard HEAD
        git -C "$dir" clean -fd
    done
}

case "$1" in
    pull)
        pull
        ;;
    status)
        status
        ;;
    master)
        main
        ;;
    main)
        main
        ;;
    reset)
        reset
        ;;
    *)
        usage
        ;;
esac
